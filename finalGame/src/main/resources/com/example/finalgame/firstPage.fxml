            <Image url="@logo3.png" />
         </image>
      </ImageView>
      <Button fx:id="sigUpButton" layoutX="419.0" layoutY="301.0" mnemonicParsing="false" onAction="#signUp" prefHeight="41.0" prefWidth="283.0" style="-fx-background-color: #ebeb05; -fx-background-radius: 100;" text="sign up">
         <font>
