         <image>
            <Image url="@Star_Wars_Logo.svg.png" />
         </image>
      </ImageView>
      <Text fill="#ebeb05" layoutX="187.0" layoutY="81.0" strokeType="OUTSIDE" strokeWidth="0.0" text="inspired by">
         <font>
            <Font name="Bodoni MT Bold Italic" size="65.0" />
         </font>
      </Text>
      <ImageView fx:id="clashLogo" fitHeight="121.0" fitWidth="227.0" layoutX="457.0" layoutY="103.0" pickOnBounds="true" preserveRatio="true">
