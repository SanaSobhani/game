<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.effect.BoxBlur?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="ancherPane" prefHeight="494.0" prefWidth="851.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.finalgame.map.Map3">
   <children>
      <ImageView fx:id="backGround" fitHeight="593.0" fitWidth="861.0" layoutX="-9.0" layoutY="-90.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@moon-sky-night-background-asset-game-2d-futuristic-generative-ai.jpg" />
         </image>
         <effect>
            <BoxBlur />
         </effect>
      </ImageView>
      <ImageView fx:id="castleImage" fitHeight="486.0" fitWidth="329.0" layoutX="200.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fx:id="ufoImage1" fitHeight="98.0" fitWidth="214.0" layoutX="23.0" layoutY="70.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fx:id="ufoImage2" fitHeight="140.0" fitWidth="308.0" layoutX="468.0" layoutY="155.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fx:id="deathStar" fitHeight="146.0" fitWidth="120.0" layoutX="644.0" layoutY="43.0" pickOnBounds="true" preserveRatio="true" />
      <Button fx:id="heroBtn" layoutX="14.0" layoutY="443.0" mnemonicParsing="false" onAction="#arrangeHeroes" style="-fx-background-radius: 100;" text="arrange heroes">
         <font>
            <Font name="Bodoni MT Bold Italic" size="17.0" />
         </font>
      </Button>
      <Button fx:id="startBtn" layoutX="14.0" layoutY="399.0" mnemonicParsing="false" onAction="#start" style="-fx-background-radius: 100;" text="start game">
         <font>
            <Font name="Bodoni MT Bold Italic" size="17.0" />
         </font>
      </Button>
      <Button fx:id="backBtn" layoutX="14.0" layoutY="354.0" mnemonicParsing="false" onAction="#back" style="-fx-background-radius: 100;" text="back">
         <font>
            <Font name="Bodoni MT Bold Italic" size="17.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
