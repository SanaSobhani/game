<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="ancherPane" prefHeight="513.0" prefWidth="857.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.finalgame.map.Map2">
   <children>
      <ImageView fx:id="backGround" fitHeight="598.0" fitWidth="908.0" layoutX="-2.0" layoutY="-1.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@sand-dunes-sahara-desert.jpg" />
         </image>
      </ImageView>
      <ImageView fx:id="castleImg" fitHeight="483.0" fitWidth="484.0" layoutX="-32.0" layoutY="21.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fx:id="canonImage1" fitHeight="240.0" fitWidth="310.0" layoutX="547.0" layoutY="270.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fx:id="canonImage2" fitHeight="209.0" fitWidth="213.0" layoutX="424.0" layoutY="190.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fx:id="canonImage3" fitHeight="240.0" fitWidth="310.0" layoutX="269.0" layoutY="270.0" pickOnBounds="true" preserveRatio="true" />
      <Button fx:id="heroBtn" layoutX="750.0" layoutY="14.0" mnemonicParsing="false" onAction="#arrangeHeroes" style="-fx-background-radius: 100;" text="arrange heroes">
         <font>
            <Font name="Bodoni MT Bold Italic" size="17.0" />
         </font>
      </Button>
      <Button fx:id="startBtn" layoutX="784.0" layoutY="58.0" mnemonicParsing="false" onAction="#start" style="-fx-background-radius: 100;" text="start game">
         <font>
            <Font name="Bodoni MT Bold Italic" size="17.0" />
         </font>
      </Button>
      <Button fx:id="backBtn" layoutX="827.0" layoutY="99.0" mnemonicParsing="false" onAction="#back" style="-fx-background-radius: 100;" text="back">
         <font>
            <Font name="Bodoni MT Bold Italic" size="17.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
