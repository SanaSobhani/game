<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="ancherPane" prefHeight="441.0" prefWidth="774.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.finalgame.map.Map1">
   <children>
      <ImageView fx:id="backGround" fitHeight="456.0" fitWidth="788.0" layoutX="-12.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@moon-surface-big-planet-background.jpg" />
         </image>
      </ImageView>
      <ImageView fx:id="soldier" fitHeight="81.0" fitWidth="51.0" layoutX="256.0" layoutY="108.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@soldeir.png" />
         </image></ImageView>
      <ImageView fx:id="watchTower" fitHeight="296.0" fitWidth="185.0" layoutX="197.0" layoutY="138.0" pickOnBounds="true" />
      <ImageView fx:id="deathStar1" fitHeight="142.0" fitWidth="208.0" layoutX="503.0" layoutY="197.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fx:id="deathStar2" fitHeight="92.0" fitWidth="134.0" layoutX="410.0" layoutY="75.0" pickOnBounds="true" preserveRatio="true" />
      <Button fx:id="heroBtn" layoutX="14.0" layoutY="389.0" mnemonicParsing="false" onAction="#arrangeHeroes" style="-fx-background-radius: 100;" text="arrange heroes">
         <font>
            <Font name="Bodoni MT Bold Italic" size="17.0" />
         </font>
      </Button>
      <Button fx:id="startBtn" layoutX="14.0" layoutY="345.0" mnemonicParsing="false" onAction="#start" style="-fx-background-radius: 100;" text="start game">
         <font>
            <Font name="Bodoni MT Bold Italic" size="17.0" />
         </font>
      </Button>
      <Button fx:id="backBtn" layoutX="14.0" layoutY="306.0" mnemonicParsing="false" onAction="#back" style="-fx-background-radius: 100;" text="back">
         <font>
            <Font name="Bodoni MT Bold Italic" size="17.0" />
         </font>
      </Button>
      <ImageView fx:id="blueRay2" fitHeight="57.0" fitWidth="79.0" layoutX="499.0" layoutY="80.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fx:id="blueRay1" fitHeight="74.0" fitWidth="117.0" layoutX="618.0" layoutY="222.0" pickOnBounds="true" preserveRatio="true" />
      <ImageView fx:id="redBall" fitHeight="13.0" fitWidth="9.0" layoutX="247.0" layoutY="117.0" pickOnBounds="true" preserveRatio="true" />
   </children>
</AnchorPane>
